# No Fridge Spoil - Environment Variables
# Copy this file to .env and fill in your keys

# Google Gemini AI (required) - Get yours at https://aistudio.google.com/apikeys
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud Text-to-Speech (optional - for Cook Mode voice)
VITE_GOOGLE_CLOUD_TTS_API_KEY=your_tts_api_key_here
